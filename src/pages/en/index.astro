---
import Layout from "@layouts/Layout.astro";
import Hero from "@components/sections/Hero.astro";
import Problem from "@components/sections/Problem.astro";
import Solution from "@components/sections/Solution.astro";
import HowItWorks from "@components/sections/HowItWorks.astro";
import UseCases from "@components/sections/UseCases.astro";
import WhyMAT from "@components/sections/WhyMAT.astro";
import Pricing from "@components/sections/Pricing.astro";
import TrustSection from "@components/sections/TrustSection.astro";
import FAQ from "@components/sections/FAQ.astro";
import ContactForm from "@components/sections/ContactForm.astro";

const lang = "en" as const;
---

<Layout lang={lang}>
  <Hero lang={lang} />
  <Problem lang={lang} />
  <Solution lang={lang} />
  <HowItWorks lang={lang} />
  <UseCases lang={lang} />
  <WhyMAT lang={lang} />
  <Pricing lang={lang} />
  <TrustSection lang={lang} />
  <FAQ lang={lang} />
  <ContactForm lang={lang} />
</Layout>
