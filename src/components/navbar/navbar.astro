---
import Container from "@components/container.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const navItems = [
  { title: "Çözüm", path: "#cozum" },
  { title: "Özellikler", path: "#ozellikler" },
  { title: "Neden MAT", path: "#neden-mat" },
  { title: "Fiyatlar", path: "#fiyatlandirma" },
  { title: "İletişim", path: "#iletisim" },
];
---

<div class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
  <Container>
    <header class="flex flex-row justify-between items-center py-3 lg:py-4">
      <Astronav>
        <div class="flex w-full lg:w-auto items-center justify-between">
          <a href={base} class="flex items-center gap-2" aria-label="MAT Ambalaj Çözümleri Ana Sayfa">
            <img
              src={`${base}images/logo-mat.png`}
              alt="MAT Ambalaj Çözümleri"
              class="h-10 lg:h-16 w-auto object-contain"
              width="256"
              height="64"
            />
          </a>
          <div class="block lg:hidden">
            <MenuIcon class="w-6 h-6 text-gray-700" />
          </div>
        </div>
        <MenuItems class="hidden w-full lg:w-auto lg:flex lg:items-center">
          <!-- Mobile dropdown panel -->
          <div class="lg:hidden border-t border-gray-100 mt-3 pt-3 pb-4">
            <ul class="flex flex-col gap-1">
              {navItems.map((item) => (
                <li>
                  <a
                    href={item.path}
                    class="flex px-3 py-3 rounded-lg items-center text-gray-700 hover:bg-teal-50 hover:text-brand-teal font-medium transition-colors duration-150 text-base">
                    {item.title}
                  </a>
                </li>
              ))}
            </ul>
            <div class="mt-4 px-1">
              <a
                href="#iletisim"
                class="block w-full text-center py-3 bg-brand-amber text-white font-semibold rounded-lg hover:bg-amber-600 transition-colors duration-150 text-sm">
                Demo Talep Et
              </a>
            </div>
          </div>
          <!-- Desktop nav -->
          <ul class="hidden lg:flex lg:flex-row lg:gap-1">
            {navItems.map((item) => (
              <li>
                <a
                  href={item.path}
                  class="flex px-4 py-2 items-center text-gray-600 hover:text-brand-teal font-medium transition-colors duration-150">
                  {item.title}
                </a>
              </li>
            ))}
          </ul>
          <div class="hidden lg:block lg:ml-4">
            <a
              href="#iletisim"
              class="inline-block px-5 py-2.5 bg-brand-amber text-white font-semibold rounded-lg hover:bg-amber-600 transition-colors duration-150 text-sm">
              Demo Talep Et
            </a>
          </div>
        </MenuItems>
      </Astronav>
    </header>
  </Container>
</div>
