---
import Container from "@components/container.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const navItems = [
  { title: "Çözüm", path: "#cozum" },
  { title: "Özellikler", path: "#ozellikler" },
  { title: "Neden MAT", path: "#neden-mat" },
  { title: "Fiyatlar", path: "#fiyatlandirma" },
  { title: "İletişim", path: "#iletisim" },
];
---

<div class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
  <Container>
    <header class="flex flex-row justify-between items-center py-4">
      <Astronav>
        <div class="flex w-full lg:w-auto items-center justify-between">
          <a href="/" class="flex items-center gap-2" aria-label="MAT Ambalaj Çözümleri Ana Sayfa">
            <img
              src={`${base}images/logo-mat.png`}
              alt="MAT Ambalaj Çözümleri"
              class="h-16 w-auto object-contain"
              width="256"
              height="64"
            />
          </a>
          <div class="block lg:hidden">
            <MenuIcon class="w-5 h-5 text-gray-700" />
          </div>
        </div>
        <MenuItems class="hidden w-full lg:w-auto lg:flex lg:items-center">
          <ul class="flex flex-col lg:flex-row lg:gap-1 mt-3 lg:mt-0">
            {navItems.map((item) => (
              <li>
                <a
                  href={item.path}
                  class="flex lg:px-4 py-2 items-center text-gray-600 hover:text-brand-teal font-medium transition-colors duration-150">
                  {item.title}
                </a>
              </li>
            ))}
          </ul>
          <div class="mt-3 lg:mt-0 lg:ml-4">
            <a
              href="#iletisim"
              class="inline-block px-5 py-2.5 bg-brand-amber text-white font-semibold rounded-lg hover:bg-amber-600 transition-colors duration-150 text-sm">
              Demo Talep Et
            </a>
          </div>
        </MenuItems>
      </Astronav>
    </header>
  </Container>
</div>
