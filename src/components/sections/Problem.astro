---
import { ui, type Lang } from "@i18n/ui";

export interface Props { lang?: Lang; }
const { lang = "tr" } = Astro.props;
const t = ui[lang].problem;

const icons = [
  `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971Z"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/></svg>`,
];
---

<section id="cozum" class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        {t.title}<br />
        <span class="text-brand-navy">{t.titleAccent}</span>
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div data-reveal-group class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {t.items.map((p, i) => (
        <div class="group relative bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 p-7 overflow-hidden">
          <div class={`absolute -top-6 -right-6 w-20 h-20 rounded-full opacity-10 ${p.iconBg}`}></div>
          <span class="absolute top-5 right-6 text-xs font-bold text-gray-200 select-none">0{i + 1}</span>
          <div class={`inline-flex items-center justify-center w-12 h-12 rounded-xl ${p.iconBg} ${p.iconColor} mb-5 group-hover:scale-110 transition-transform duration-300`} set:html={icons[i]} />
          <h3 class="font-bold text-gray-900 text-base mb-2">{p.title}</h3>
          <p class="text-gray-600 text-[15px] leading-relaxed">{p.body}</p>
          <div class={`absolute bottom-0 left-0 h-0.5 w-0 group-hover:w-full transition-all duration-500 rounded-full ${p.accent.replace('border-', 'bg-')}`}></div>
        </div>
      ))}
    </div>

    <div data-reveal class="mt-16 text-center">
      <blockquote class="inline-block max-w-2xl px-6">
        <div class="text-6xl font-serif text-brand-teal leading-none mb-2 select-none">"</div>
        <p class="text-gray-800 font-semibold text-xl lg:text-2xl leading-snug tracking-tight mb-4">
          {t.quote}
          <span class="text-brand-teal"> {t.quoteAccent}</span><br />
          {t.quoteEnd}
        </p>
        <div class="flex items-center justify-center gap-3">
          <div class="h-px w-10 bg-gray-300"></div>
          <span class="text-xs font-semibold text-gray-400 uppercase tracking-widest">{t.quoteMeta}</span>
          <div class="h-px w-10 bg-gray-300"></div>
        </div>
      </blockquote>
    </div>
  </div>
</section>
