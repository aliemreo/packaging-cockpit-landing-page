---
---

<section class="pt-10 pb-16 lg:pt-14 lg:pb-24 bg-gradient-to-br from-white to-teal-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <!-- Partner Badge -->
        <div data-reveal class="mb-8">
          <div class="flex items-center gap-5 mb-3">
            <img
              src={`${import.meta.env.BASE_URL}images/logo-pc.png`}
              alt="Packaging Cockpit"
              class="h-28 w-auto object-contain max-w-xs"
              width="400"
              height="112"
            />
            <div class="w-px h-20 bg-gray-300 flex-shrink-0"></div>
            <img
              src={`${import.meta.env.BASE_URL}images/logo-mat.png`}
              alt="MAT Ambalaj Çözümleri"
              class="h-16 w-auto object-contain"
              width="200"
              height="64"
            />
          </div>
          <div class="inline-flex items-center gap-2 bg-teal-50 border border-brand-teal/30 rounded-full px-4 py-1.5">
            <svg class="w-3.5 h-3.5 text-brand-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm font-semibold text-brand-teal">Türkiye Yetkili Satıcısı · MAT Ambalaj Çözümleri</span>
          </div>
        </div>

        <h1 data-reveal class="text-4xl lg:text-5xl font-bold text-gray-900 leading-tight tracking-tight mb-6">
          Ambalajınızın Sürdürülebilirlik Performansını
          <span class="text-brand-teal"> Bilimsel Standartlarla</span> Ölçün
        </h1>

        <p data-reveal class="text-lg text-gray-600 mb-8 leading-relaxed">
          Avusturya merkezli Packaging Cockpit GmbH ile iş birliği içinde, Türkiye'deki yetkili satıcı MAT Ambalaj Çözümleri olarak PPWR uyumluluğu, geri dönüşülebilirlik analizi ve yaşam döngüsü değerlendirmesi konusunda hizmet sunuyoruz. Ambalaj portföyünüzü geleceğe hazırlayın.
        </p>

        <div data-reveal class="flex flex-col sm:flex-row gap-4 mb-6">
          <a
            href="#fiyatlandirma"
            class="inline-flex items-center justify-center px-7 py-3.5 bg-brand-teal text-white font-semibold rounded-lg hover:bg-teal-800 transition-colors duration-150 text-base shadow-md">
            Ücretsiz Başlayın
          </a>
          <a
            href="#iletisim"
            class="inline-flex items-center justify-center px-7 py-3.5 bg-brand-amber text-white font-semibold rounded-lg hover:bg-amber-600 transition-colors duration-150 text-base shadow-md">
            Demo Talep Et
          </a>
        </div>
        <p data-reveal class="text-sm text-gray-500 mb-6">
          Ücretsiz Basic sürümle hemen başlayın — kredi kartı gerekmez. Gelişmiş özellikler için <a href="#fiyatlandirma" class="text-brand-teal font-medium hover:underline">paketlere bakın</a>.
        </p>

        <!-- Expert social proof -->
        <a data-reveal href="#iletisim" class="inline-flex items-center gap-3 group">
          <img
            src={`${import.meta.env.BASE_URL}images/kaan-pp.jpg`}
            alt="Kaan Yalcinkaya"
            class="w-10 h-10 rounded-full object-cover ring-2 ring-brand-teal/30 group-hover:ring-brand-teal transition-all duration-200"
            width="40"
            height="40"
          />
          <span class="text-sm text-gray-600 group-hover:text-brand-teal transition-colors duration-200">
            <span class="font-semibold text-gray-800">Kaan Yalcinkaya</span> ile 30 dk. ücretsiz görüşün →
          </span>
        </a>

        <!-- Trust bar -->
        <div class="border-t border-gray-200 pt-6">
          <p class="text-sm text-gray-500 font-medium mb-2">Avrupa'nın öncü markalarının güvendiği platform</p>
          <div class="flex flex-wrap gap-4 items-center">
            {["SPAR Austria", "BILLA", "BIPA", "PreZero"].map((brand) => (
              <span class="text-sm font-semibold text-gray-400 uppercase tracking-wide">{brand}</span>
            ))}
          </div>
        </div>

      </div>

      <!-- Hero Dashboard Mockup -->
      <div class="flex justify-center lg:justify-end">
        <div class="w-full max-w-md bg-white rounded-2xl shadow-2xl border border-gray-100 overflow-hidden">

          <!-- Window chrome -->
          <div class="bg-gray-50 border-b border-gray-200 px-4 py-3 flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-red-400"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
            <div class="w-3 h-3 rounded-full bg-green-400"></div>
            <div class="ml-3 flex-1 bg-white rounded-md px-3 py-1 text-xs text-gray-400 border border-gray-200">
              packaging-cockpit.com
            </div>
          </div>

          <!-- Dashboard body -->
          <div class="p-5">

            <!-- Product name row -->
            <div class="flex items-center justify-between mb-4">
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide font-medium">Analiz Raporu</p>
                <p class="text-sm font-bold text-gray-800">PET Şişe 500ml · Almanya</p>
              </div>
              <span class="text-xs bg-green-100 text-green-700 font-semibold px-2.5 py-1 rounded-full">✓ PPWR Uyumlu</span>
            </div>

            <!-- Metric cards -->
            <div class="grid grid-cols-3 gap-3 mb-4">
              <div class="bg-teal-50 rounded-xl p-3 text-center">
                <p class="text-2xl font-bold text-teal-700">94%</p>
                <p class="text-xs text-teal-600 mt-0.5 leading-tight">Geri Dönüşülebilirlik</p>
              </div>
              <div class="bg-blue-50 rounded-xl p-3 text-center">
                <p class="text-2xl font-bold text-blue-700">-42%</p>
                <p class="text-xs text-blue-600 mt-0.5 leading-tight">CO₂ Azaltım</p>
              </div>
              <div class="bg-amber-50 rounded-xl p-3 text-center">
                <p class="text-2xl font-bold text-amber-600">27</p>
                <p class="text-xs text-amber-600 mt-0.5 leading-tight">AB Ülkesi</p>
              </div>
            </div>

            <!-- Recyclability bar chart -->
            <div class="bg-gray-50 rounded-xl p-4 mb-4">
              <p class="text-xs font-semibold text-gray-500 mb-3 uppercase tracking-wide">Ülkeye Göre Geri Dönüşülebilirlik</p>
              <div class="space-y-2">
                {[
                  { label: "Almanya", pct: 94, color: "bg-teal-500" },
                  { label: "Fransa", pct: 81, color: "bg-teal-400" },
                  { label: "Türkiye", pct: 67, color: "bg-amber-400" },
                  { label: "Polonya", pct: 58, color: "bg-orange-400" },
                ].map(({ label, pct, color }) => (
                  <div class="flex items-center gap-2">
                    <span class="text-xs text-gray-500 w-14 flex-shrink-0">{label}</span>
                    <div class="flex-1 bg-gray-200 rounded-full h-2">
                      <div class={`${color} h-2 rounded-full`} style={`width: ${pct}%`}></div>
                    </div>
                    <span class="text-xs font-semibold text-gray-700 w-8 text-right">{pct}%</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- LCA summary row -->
            <div class="flex items-center justify-between bg-brand-navy/5 rounded-xl px-4 py-3">
              <div class="flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-brand-navy"></div>
                <span class="text-xs font-medium text-gray-600">LCA Tamamlandı</span>
              </div>
              <span class="text-xs text-gray-400">16 etki kategorisi analiz edildi</span>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
</section>
