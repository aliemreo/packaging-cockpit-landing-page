---
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const brands = ["SPAR Austria", "BILLA", "BIPA", "PreZero"];
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <div class="flex justify-center mb-6">
          <img
            src={`${base}images/logo-pc.png`}
            alt="Packaging Cockpit"
            class="h-12 w-auto object-contain"
            width="200"
            height="48"
          />
        </div>
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Avrupa'nın Öncü Markaları<br />
          <span class="text-brand-teal">Packaging Cockpit'e Güveniyor</span>
        </h2>
      </div>

      <!-- Brand logos as text chips -->
      <div data-reveal-group class="flex flex-wrap justify-center gap-4 mb-12">
        {brands.map((brand) => (
          <div class="px-6 py-3 bg-gray-100 rounded-xl text-gray-700 font-bold text-lg tracking-wide">
            {brand}
          </div>
        ))}
      </div>

      <p class="text-center text-gray-600 text-base leading-relaxed mb-10 max-w-2xl mx-auto">
        SPAR Austria, BILLA, BIPA ve PreZero gibi şirketler özel marka (private label) ambalaj verilerini Packaging Cockpit üzerinden yönetiyor. Platform, World Packaging Organization (WPO) ve FH Campus Wien ile bilimsel işbirliği içinde sürekli güncelleniyor.
      </p>

      <!-- Scientific backing -->
      <div data-reveal-group class="grid sm:grid-cols-2 gap-6">
        <div class="bg-brand-navy/5 border border-brand-navy/20 rounded-xl p-6 text-center">
          <div class="flex justify-center mb-3">
            <svg class="w-8 h-8 text-brand-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/>
            </svg>
          </div>
          <h3 class="font-bold text-brand-navy mb-2">FH Campus Wien</h3>
          <p class="text-sm text-gray-600">Circular Packaging Design Guidelines — bilimsel metodoloji temeli</p>
        </div>
        <div class="bg-brand-teal/5 border border-brand-teal/20 rounded-xl p-6 text-center">
          <div class="flex justify-center mb-3">
            <svg class="w-8 h-8 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253M3.284 14.253A8.959 8.959 0 0 1 3 12c0-1.596.415-3.099 1.157-4.418"/>
            </svg>
          </div>
          <h3 class="font-bold text-brand-teal mb-2">World Packaging Organization</h3>
          <p class="text-sm text-gray-600">WPO standartları ve uluslararası bilimsel işbirliği</p>
        </div>
      </div>

      <div class="mt-8 text-center">
        <a
          href="https://packaging-cockpit.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-brand-teal font-semibold hover:underline text-sm">
          Packaging Cockpit resmi sitesini ziyaret edin
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
