---
const values = [
  {
    title: "Türkiye'nin Tek Yetkili Satıcısı",
    body: "Packaging Cockpit'i Türkiye'de resmi olarak temsil eden tek kuruluşuz. Avusturya merkezli Packaging Cockpit GmbH ile doğrudan iş birliği içindeyiz.",
  },
  {
    title: "Türkçe Destek ve Eğitim",
    body: "Ekibiniz platformu Türkçe kaynaklar ve birebir eğitimle kullanmaya başlar. Destek süreçleri tamamen Türkçe yürür.",
  },
  {
    title: "Yerel Mevzuat Danışmanlığı",
    body: "Türkiye Sıfır Atık mevzuatı, Çevre Bakanlığı düzenlemeleri ve AB uyum süreçlerinde yerel bilgi birikimimizle size rehberlik ederiz.",
  },
  {
    title: "İçerik ve Teknik Destek",
    body: "Uygulama ortağı olarak içerik ve teknik destek konusunda hizmet vermekteyiz. Veri girişinden raporlamaya kadar her aşamada yanınızdayız.",
  },
  {
    title: "Uygulama Ortaklığı",
    body: "Packaging Cockpit'in Türkiye'deki uygulama ortağı sıfatıyla, platformun kurulumu, yapılandırması ve kullanıma alınması süreçlerini yönetiyoruz.",
  },
  {
    title: "Entegrasyon Desteği",
    body: "Mevcut ERP (SAP, Logo, Netsis) ve PIM sistemlerinizle Packaging Cockpit entegrasyonunu birlikte tasarlarız.",
  },
];
---

<section id="neden-mat" class="py-20 bg-teal-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        Neden MAT Ambalaj Çözümleri?
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Packaging Cockpit'in Türkiye'deki yetkili satıcısı olarak, sadece yazılıma erişim değil, uçtan uca içerik ve teknik destek sunuyoruz.
      </p>
    </div>

    <div data-reveal-group class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {values.map((v, i) => (
        <div class="group relative bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 p-7 overflow-hidden">
          <!-- Left accent bar -->
          <div class="absolute left-0 top-6 bottom-6 w-1 bg-brand-teal/20 rounded-full group-hover:bg-brand-teal group-hover:top-0 group-hover:bottom-0 transition-all duration-300"></div>
          <!-- Number badge -->
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-xl bg-brand-navy text-white text-sm font-bold mb-5 ml-3">
            {String(i + 1).padStart(2, '0')}
          </div>
          <div class="ml-3">
            <h3 class="font-bold text-gray-900 text-base mb-2 group-hover:text-brand-teal transition-colors duration-200">{v.title}</h3>
            <p class="text-gray-600 text-[15px] leading-relaxed">{v.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
