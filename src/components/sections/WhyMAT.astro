---
import { ui, type Lang } from "@i18n/ui";

export interface Props { lang?: Lang; }
const { lang = "tr" } = Astro.props;
const t = ui[lang].whyMAT;
---

<section id="neden-mat" class="py-20 bg-teal-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">{t.title}</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div data-reveal-group class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {t.values.map((v, i) => (
        <div class="group relative bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 p-7 overflow-hidden">
          <div class="absolute left-0 top-6 bottom-6 w-1 bg-brand-teal/20 rounded-full group-hover:bg-brand-teal group-hover:top-0 group-hover:bottom-0 transition-all duration-300"></div>
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-xl bg-brand-navy text-white text-sm font-bold mb-5 ml-3">
            {String(i + 1).padStart(2, '0')}
          </div>
          <div class="ml-3">
            <h3 class="font-bold text-gray-900 text-base mb-2 group-hover:text-brand-teal transition-colors duration-200">{v.title}</h3>
            <p class="text-gray-600 text-[15px] leading-relaxed">{v.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
