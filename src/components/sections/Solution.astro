---

<section id="ozellikler" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        Packaging Cockpit:<br />
        <span class="text-brand-teal">Bilim Temelli Ambalaj Karar Platformu</span>
      </h2>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto mb-6">
        Packaging Cockpit, ambalajlarınızın çeşitli metriklerini hesaplamanıza olanak tanıyan kapsamlı bir çevrimiçi araçtır. Hedef pazara bağlı olarak ülkeye özel geri dönüştürülebilirlik oranlarını, karbon ayak izini ve bir yaşam döngüsü analizinin diğer etki kategorilerini hesaplamak mümkündür. Ayrıca toplanan verileri araç içinde yönetebilir ve seçtiğiniz müşteriler veya tedarikçilerle paylaşabilirsiniz. Platform, FH Campus Wien'in Circular Packaging Design Guidelines'ı ve World Packaging Organization standartları üzerine kurulmuştur.
      </p>
      <!-- Award badge -->
      <div class="inline-flex items-center gap-2 bg-amber-50 border border-amber-200 rounded-full px-5 py-2">
        <svg class="w-4 h-4 text-amber-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0"/>
        </svg>
        <span class="text-sm font-semibold text-amber-700">Federal Ecodesign Award 2024 Adayı</span>
      </div>
    </div>

    <div data-reveal-group class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f, i) => (
        <div class="group relative bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 p-7 overflow-hidden">
          <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-teal-50 to-transparent rounded-bl-full opacity-60"></div>
          <div class="relative inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-brand-teal/10 to-brand-teal/20 text-brand-teal mb-5 group-hover:from-brand-teal/20 group-hover:to-brand-teal/30 transition-colors duration-300" set:html={f.icon} />
          <span class="absolute top-6 right-7 text-xs font-bold text-gray-200 select-none">0{i + 1}</span>
          <h3 class="font-bold text-gray-900 text-base mb-2 group-hover:text-brand-teal transition-colors duration-200">{f.title}</h3>
          <p class="text-gray-600 text-[15px] leading-relaxed">{f.body}</p>
          <div class="absolute bottom-0 left-0 h-0.5 w-0 bg-brand-teal group-hover:w-full transition-all duration-500 rounded-full"></div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a
        href="#iletisim"
        class="inline-flex items-center justify-center px-8 py-3.5 bg-brand-teal text-white font-semibold rounded-lg hover:bg-teal-800 transition-colors duration-150 text-base shadow">
        Platformu Keşfedin — Demo Talep Et
      </a>
    </div>
  </div>
</section>
