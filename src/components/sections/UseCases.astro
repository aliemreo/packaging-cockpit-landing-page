---
const personas = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z"/></svg>`,
    title: "Ambalaj Üreticileri",
    body: "Müşterilerinize sürdürülebilir ambalaj alternatifleri sunun. Farklı tasarımların geri dönüşülebilirlik ve maliyet etkisini veriye dayalı karşılaştırın. Rekabet avantajı elde edin.",
    tag: "Üretim",
    tagColor: "bg-teal-100 text-teal-700",
    iconBg: "bg-teal-100",
    iconColor: "text-teal-600",
    stripe: "bg-teal-400",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/></svg>`,
    title: "Marka Sahipleri",
    subtitle: "FMCG, Gıda, Kozmetik",
    body: "Ürün portföyünüzün AB pazarlarındaki uyumluluk durumunu görün. PPWR hazırlığı yapın, plastik vergi maliyetlerini optimize edin, sürdürülebilirlik raporlamanızı veri ile besleyin.",
    tag: "FMCG & Kozmetik",
    tagColor: "bg-blue-100 text-blue-700",
    iconBg: "bg-blue-100",
    iconColor: "text-blue-600",
    stripe: "bg-blue-400",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z"/></svg>`,
    title: "Perakende Zincirleri",
    body: "Özel markalı (private label) ürünlerinizin ambalaj verilerini merkezi olarak yönetin. Tedarikçi verilerini standardize edin, sürdürülebilirlik hedeflerinize ulaşın.",
    tag: "Perakende",
    tagColor: "bg-purple-100 text-purple-700",
    iconBg: "bg-purple-100",
    iconColor: "text-purple-600",
    stripe: "bg-purple-400",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 17h18l2-5H2v5Z"/><path d="M5 12V8h6v4"/><path d="M8 8V5.5"/><path d="M1 20.5c1.2-.8 2.4-.8 3.5 0 1.2.8 2.4.8 3.5 0 1.2-.8 2.4-.8 3.5 0 1.2.8 2.4.8 3.5 0 1.2-.8 2.4-.8 3.5 0"/></svg>`,
    title: "İhracatçılar",
    body: "Hedef pazarlarınızın ülke-spesifik regülasyonlarına göre ambalajlarınızı değerlendirin. Gümrük ve uyum süreçlerinde gerekli dokümantasyonu hızlıca oluşturun.",
    tag: "İhracat",
    tagColor: "bg-amber-100 text-amber-700",
    iconBg: "bg-amber-100",
    iconColor: "text-amber-600",
    stripe: "bg-amber-400",
  },
];
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        Kimler İçin?
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Packaging Cockpit, ambalaj değer zincirinin her halkasında değer yaratır.
      </p>
    </div>

    <div data-reveal-group class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {personas.map((p) => (
        <div class="group relative flex flex-col bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden">
          <div class={`h-1 w-full ${p.stripe}`}></div>
          <div class="p-7 flex flex-col flex-1">
            <div class={`inline-flex items-center justify-center w-14 h-14 rounded-2xl ${p.iconBg} ${p.iconColor} mb-5`} set:html={p.icon} />
            <div class="mb-3">
              <span class={`inline-block text-xs font-semibold px-2.5 py-1 rounded-full ${p.tagColor} mb-2`}>{p.tag}</span>
              <h3 class="font-bold text-gray-900 text-base leading-tight group-hover:text-brand-teal transition-colors duration-200">{p.title}</h3>
              {p.subtitle && <p class="text-xs text-gray-400 mt-0.5">{p.subtitle}</p>}
            </div>
            <p class="text-gray-600 text[15px] leading-relaxed flex-1">{p.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
