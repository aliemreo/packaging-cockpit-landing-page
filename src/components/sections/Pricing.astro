---
const plans = [
  {
    id: "basic",
    name: "Basic",
    tag: "Ücretsiz",
    tagColor: "bg-teal-100 text-teal-700",
    highlight: false,
    cta: "Ücretsiz Kaydol",
    ctaLink: "https://packaging-cockpit.com",
    ctaExternal: true,
    ctaStyle: "border-2 border-brand-teal text-brand-teal hover:bg-teal-50",
    description: "Platform keşfi ve temel geri dönüşülebilirlik hesaplamaları için.",
  },
  {
    id: "baslangic",
    name: "Başlangıç",
    tag: "Popüler",
    tagColor: "bg-blue-100 text-blue-700",
    highlight: false,
    cta: "Teklif Al",
    ctaLink: "#iletisim",
    ctaExternal: false,
    ctaStyle: "border-2 border-gray-300 text-gray-700 hover:border-brand-teal hover:text-brand-teal",
    description: "10 ülke kapsamı ve ekip çalışması için.",
  },
  {
    id: "ileri",
    name: "İleri",
    tag: "Önerilen",
    tagColor: "bg-amber-100 text-amber-700",
    highlight: true,
    cta: "Teklif Al",
    ctaLink: "#iletisim",
    ctaExternal: false,
    ctaStyle: "bg-brand-teal text-white hover:bg-teal-800",
    description: "AB geneli analiz ve tam LCA desteği.",
  },
  {
    id: "ileri-plus",
    name: "İleri+",
    tag: "Kurumsal",
    tagColor: "bg-purple-100 text-purple-700",
    highlight: false,
    cta: "Teklif Al",
    ctaLink: "#iletisim",
    ctaExternal: false,
    ctaStyle: "border-2 border-gray-300 text-gray-700 hover:border-brand-teal hover:text-brand-teal",
    description: "Tüm dünya pazarları ve kurumsal kapasite.",
  },
];

// Cell types: "check" | "dash" | text string
const rows: { label: string; values: string[] }[] = [
  { label: "Geri dön. hesaplamaları",       values: ["50 kredi",          "Sınırsız",   "Sınırsız",                        "Sınırsız"] },
  { label: "Maliyet hesaplamaları",          values: ["dash",              "check",      "check",                           "check"] },
  { label: "Güncel hesaplamalar",            values: ["dash",              "check",      "check",                           "check"] },
  { label: "İhraç edilen ülke sayısı",       values: ["İspanya",           "10 ülke",    "Tüm AB",                          "Tüm ülkeler"] },
  { label: "Standart kullanıcı",             values: ["1",                 "5",          "20",                              "60"] },
  { label: "Veri seti kapasitesi",           values: ["1.000",             "50.000",     "250.000",                         "750.000"] },
  { label: "Dosya depolama",                 values: ["1 GB",              "20 GB",      "100 GB",                          "300 GB"] },
  { label: "Özelleştirilebilir alanlar",     values: ["dash",              "10",         "20",                              "100"] },
  { label: "Excel Yükleme / İndirme",        values: ["Yalnızca yükleme",  "check",      "check",                           "check"] },
  { label: "Kick-off workshopu",             values: ["dash",              "1 gün",      "2 gün",                           "4 gün"] },
  { label: "Destek ve danışmanlık",          values: ["dash",              "20 saat",    "40 saat",                         "60 saat"] },
  { label: "Yaşam döngüsü analizi (LCA)",    values: ["dash",              "dash",       "Karbon ayakizi (Cradle to Grave)", "Tüm 16 kategori"] },
  { label: "LCA kullanım sayısı",            values: ["dash",              "dash",       "5",                               "10"] },
  { label: "Gelecek PPWR güncellemeleri",    values: ["dash",              "dash",       "check",                           "check"] },
];
---

<section id="fiyatlandirma" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        Planlar ve Özellikler
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-4">
        Ücretsiz Basic sürümüyle bugün başlayın. Portföyünüz büyüdükçe plan değiştirin.
      </p>
      <div class="inline-flex items-center gap-2 bg-teal-50 border border-teal-200 rounded-full px-5 py-2 text-sm text-teal-800 font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Paket fiyatları için MAT Ambalaj Çözümleri ile iletişime geçin — size özel teklif sunulur.
      </div>
    </div>

    <!-- Plan cards -->
    <div data-reveal-group class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      {plans.map((plan) => (
        <div class={`rounded-2xl p-6 border-2 flex flex-col ${plan.highlight ? 'border-brand-teal bg-teal-50 shadow-lg' : 'border-gray-200 bg-white'}`}>
          <div class="mb-4">
            <span class={`inline-block text-xs font-semibold px-2.5 py-1 rounded-full ${plan.tagColor} mb-3`}>
              {plan.tag}
            </span>
            <h3 class="text-xl font-bold text-gray-900">{plan.name}</h3>
            <p class="text-sm text-gray-500 mt-1.5 leading-relaxed">{plan.description}</p>
          </div>
          <div class="mt-auto pt-4">
            {plan.ctaExternal ? (
              <a
                href={plan.ctaLink}
                target="_blank"
                rel="noopener noreferrer"
                class={`block w-full text-center py-2.5 rounded-lg font-semibold text-sm transition-colors duration-150 ${plan.ctaStyle}`}>
                {plan.cta}
              </a>
            ) : (
              <a
                href={plan.ctaLink}
                class={`block w-full text-center py-2.5 rounded-lg font-semibold text-sm transition-colors duration-150 ${plan.ctaStyle}`}>
                {plan.cta}
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Feature comparison table -->
    <div data-reveal class="overflow-x-auto rounded-2xl border border-gray-200 shadow-sm">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b-2 border-gray-200 bg-gray-50">
            <th class="text-left px-5 py-4 font-semibold text-gray-500 uppercase tracking-wide text-xs w-[36%]">Özellik</th>
            {plans.map((plan) => (
              <th class={`px-4 py-4 font-bold text-center text-sm ${plan.highlight ? 'text-brand-teal bg-teal-50/60' : 'text-gray-700'}`}>
                {plan.name}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => (
            <tr class={`border-b border-gray-100 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50/40'}`}>
              <td class="px-5 py-3.5 text-gray-700 font-medium text-[13px]">{row.label}</td>
              {row.values.map((val, j) => (
                <td class={`px-4 py-3.5 text-center ${plans[j].highlight ? 'bg-teal-50/30' : ''}`}>
                  {val === "check" ? (
                    <span class="inline-flex items-center justify-center">
                      <svg class="w-5 h-5 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                      </svg>
                    </span>
                  ) : val === "dash" ? (
                    <span class="inline-flex items-center justify-center">
                      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
                      </svg>
                    </span>
                  ) : (
                    <span class="text-gray-700 font-medium text-[13px]">{val}</span>
                  )}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p data-reveal class="text-center text-xs text-gray-400 mt-5">
      Packaging Cockpit GmbH tarafından belirlenen planlardır. Fiyat ve kapsam bilgisi için
      <a href="#iletisim" class="text-brand-teal hover:underline">MAT Ambalaj Çözümleri</a>
      ile iletişime geçin.
    </p>

  </div>
</section>
