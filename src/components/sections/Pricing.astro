---
import { ui, type Lang } from "@i18n/ui";

export interface Props { lang?: Lang; }
const { lang = "tr" } = Astro.props;
const t = ui[lang].pricing;
---

<section id="fiyatlandirma" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">{t.title}</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-4">{t.subtitle}</p>
      <div class="inline-flex items-center gap-2 bg-teal-50 border border-teal-200 rounded-full px-5 py-2 text-sm text-teal-800 font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        {t.infoBadge}
      </div>
    </div>

    <!-- Plan cards -->
    <div data-reveal-group class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      {t.plans.map((plan) => (
        <div class={`rounded-2xl p-6 border-2 flex flex-col ${plan.highlight ? 'border-brand-teal bg-teal-50 shadow-lg' : 'border-gray-200 bg-white'}`}>
          <div class="mb-4">
            <span class={`inline-block text-xs font-semibold px-2.5 py-1 rounded-full ${plan.tagColor} mb-3`}>
              {plan.tag}
            </span>
            <h3 class="text-xl font-bold text-gray-900">{plan.name}</h3>
            <p class="text-sm text-gray-500 mt-1.5 leading-relaxed">{plan.description}</p>
          </div>
          <div class="mt-auto pt-4">
            <a
              href="#iletisim"
              data-plan={plan.name}
              class={`block w-full text-center py-2.5 rounded-lg font-semibold text-sm transition-colors duration-150 ${plan.ctaStyle}`}>
              {plan.cta}
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Feature comparison table -->
    <div data-reveal class="overflow-x-auto rounded-2xl border border-gray-200 shadow-sm">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b-2 border-gray-200 bg-gray-50">
            <th class="text-left px-5 py-4 font-semibold text-gray-500 uppercase tracking-wide text-xs w-[36%]">{t.featureColLabel}</th>
            {t.plans.map((plan) => (
              <th class={`px-4 py-4 font-bold text-center text-sm ${plan.highlight ? 'text-brand-teal bg-teal-50/60' : 'text-gray-700'}`}>
                {plan.name}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {t.rows.map((row, i) => (
            <tr class={`border-b border-gray-100 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50/40'}`}>
              <td class="px-5 py-3.5 text-gray-700 font-medium text-[13px]">{row.label}</td>
              {row.values.map((val, j) => (
                <td class={`px-4 py-3.5 text-center ${t.plans[j].highlight ? 'bg-teal-50/30' : ''}`}>
                  {val === "check" ? (
                    <span class="inline-flex items-center justify-center">
                      <svg class="w-5 h-5 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                      </svg>
                    </span>
                  ) : val === "dash" ? (
                    <span class="inline-flex items-center justify-center">
                      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
                      </svg>
                    </span>
                  ) : (
                    <span class="text-gray-700 font-medium text-[13px]">{val}</span>
                  )}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p data-reveal class="text-center text-xs text-gray-400 mt-5">
      {t.footnote}{" "}
      <a href="#iletisim" class="text-brand-teal hover:underline">{t.footnoteLink}</a>
      {" "}{t.footnoteSuffix}
    </p>

  </div>
</section>
