---
const year = new Date().getFullYear();

const quickLinks = [
  { title: "Çözüm", path: "#cozum" },
  { title: "Özellikler", path: "#ozellikler" },
  { title: "Neden MAT", path: "#neden-mat" },
  { title: "İletişim", path: "#iletisim" },
];

const legalLinks = [
  { title: "Gizlilik Politikası", path: "#" },
  { title: "KVKK Aydınlatma Metni", path: "#" },
];
---

<footer class="bg-gray-900 text-gray-400">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10 mb-12">

      <!-- Col 1: Brand -->
      <div>
        <div class="mb-5">
          <img
            src={`${import.meta.env.BASE_URL}images/logo-mat.png`}
            alt="MAT Ambalaj Çözümleri"
            class="h-10 w-auto object-contain brightness-0 invert"
            width="180"
            height="40"
          />
        </div>
        <p class="text-sm leading-relaxed mb-4 text-gray-400">
          Ambalaj sürdürülebilirliği ve PPWR uyum çözümleri. Packaging Cockpit Türkiye Yetkili Satıcısı.
        </p>
        <div class="inline-flex items-center gap-1.5 bg-brand-teal/20 border border-brand-teal/30 rounded-full px-3 py-1">
          <svg class="w-3.5 h-3.5 text-brand-teal" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span class="text-xs font-semibold text-brand-teal">Yetkili Partner</span>
        </div>
      </div>

      <!-- Col 2: Links -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Hızlı Erişim</h3>
        <ul class="space-y-2 mb-6">
          {quickLinks.map((link) => (
            <li>
              <a href={link.path} class="text-sm hover:text-white transition-colors duration-150">{link.title}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">İletişim</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span>İstanbul, Türkiye</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:info@matpack.net" class="hover:text-white transition-colors">info@matpack.net</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-gray-500" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
            <a href="#" class="hover:text-white transition-colors">LinkedIn</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-800 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs">
      <p>© {year} MAT Ambalaj Çözümleri. Tüm hakları saklıdır.</p>
      <p class="text-center">
        Packaging Cockpit, Packaging Cockpit GmbH'nin tescilli markasıdır. |{" "}
        <a
          href="https://packaging-cockpit.com"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-white transition-colors">
          packaging-cockpit.com
        </a>
      </p>
    </div>
  </div>
</footer>
